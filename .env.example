# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Tavily Configuration (Research)
TAVILY_API_KEY=your_tavily_api_key

# Twitter / X API Configuration
TWITTER_APP_KEY=your_twitter_api_key
TWITTER_APP_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# Reddit API Configuration
REDDIT_USER_AGENT="ZenlotContentAgent/1.0.0 by YourUsername"
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password
EMAIL_FROM="Zenlot Agent <your_email@gmail.com>"
EMAIL_TO="info@zenlot.net"

# Application Settings
DRY_RUN=true # Set to false to actually post and send emails
